# Copy this file to .env and fill in your real values.
# On Vercel, set these in Project Settings → Environment Variables instead.

# Resend API key (https://resend.com) — used for booking notification emails.
RESEND_API_KEY=re_your_api_key_here

# Sender address. Must be a verified Resend domain. The default below works
# for testing without a verified domain.
RESEND_FROM=Tony's Detailing <onboarding@resend.dev>

# Optional: override the SQLite database path.
# DATABASE_PATH=bookings.db

# Optional: Google Sheets backup. Paste the /exec URL of a deployed Google
# Apps Script web app (see tools/sheets-backup.gs). When set, each booking is
# also POSTed here as JSON and appended as a row. Leave unset to disable.
# SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/AKfyc.../exec
